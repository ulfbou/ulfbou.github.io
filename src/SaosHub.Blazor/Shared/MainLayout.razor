@inherits LayoutComponentBase
@inject IJSRuntime JS

<div id="boot" class="@(_bootHidden ? "hidden" : "")">
  <div class="boot-logo">SAOS</div>
  <div class="boot-sub">Static Application Operating System</div>
  <div class="boot-bar-wrap"><div class="boot-bar" id="bootBar" style="width:@_bootProgress%"></div></div>
  <div class="boot-msg" id="bootMsg">@_bootMsg</div>
</div>

<div id="os" class="@(_osVisible ? "visible" : "")">
  <TitleBar CurrentPath="@_currentPath" />
  <div class="shell">
    <Sidebar OnNavigate="HandleNavigate" ActiveView="@_activeView" />
    <main class="main">
      @Body
    </main>
  </div>
</div>

@code {
    private bool _bootHidden = false;
    private bool _osVisible = false;
    private int _bootProgress = 0;
    private string _bootMsg = "Initializing kernel...";
    private string _activeView = "overview";
    private string _currentPath = "infrastructure-roadmap";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("saosBoot.start", DotNetObjectReference.Create(this));
        }
    }

    [JSInvokable]
    public void UpdateBoot(int progress, string msg)
    {
        _bootProgress = progress;
        _bootMsg = msg;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void BootComplete()
    {
        _bootHidden = true;
        _osVisible = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleNavigate(string view)
    {
        _activeView = view;
        _currentPath = view;
    }
}

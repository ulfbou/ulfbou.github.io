<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Ulfbou.Site.Shared.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(Ulfbou.Site.Shared.MainLayout)">
            <p role="alert" style="padding:2rem">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>
